
# Container images (release v1.0.1 on GHCR; override for local builds)
# DATASAFE_SERVER_IMAGE=ghcr.io/direktorbani/datasafe-storage-server:v1.0.1
# DATASAFE_CONSOLE_IMAGE=ghcr.io/direktorbani/datasafe-console:v1.0.1
STORAGE_ADDR=:9000
STORAGE_LOG_LEVEL=info
# Native dev (storage-server on host): where metadata.db and objects/ live.
STORAGE_DATA_DIR=./data
# Docker Compose bind mounts (required overlay docker-compose.local-data.yml on Windows local dev).
# Windows local dev default — keep postgres + object data on D: (forward slashes):
DATASAFE_DATA_ROOT=D:/datasafe-data
# Linux/macOS: comment out the line above or set e.g. DATASAFE_DATA_ROOT=/var/lib/datasafe
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=datasafe
STORAGE_SECRET_KEY=datasafesecret

# Admin console JWT auth (default credentials for local dev only — rotate in production)
STORAGE_ADMIN_USER=admin
STORAGE_ADMIN_PASSWORD=admin
STORAGE_JWT_SECRET=datasafe-jwt-secret
# Set STORAGE_DEV=true to skip startup secret warnings during local development.
STORAGE_DEV=true
# Set STORAGE_STRICT_SECRETS=true to refuse startup when default JWT/secret/admin password are used.
# STORAGE_STRICT_SECRETS=false

# Metadata backend: bolt (default, embedded) or postgres (production)
STORAGE_METADATA_BACKEND=bolt
# STORAGE_METADATA_BACKEND=postgres
# STORAGE_POSTGRES_DSN=postgres://datasafe:datasafe@localhost:5432/datasafe?sslmode=disable
# Optional read replica for list-style metadata queries (bucket/object lists).
# STORAGE_POSTGRES_READ_REPLICA_DSN=postgres://datasafe:datasafe@localhost:5433/datasafe?sslmode=disable
# Host for native dev (storage-server on host). Docker Compose always uses service name "postgres".
STORAGE_POSTGRES_HOST=localhost
STORAGE_POSTGRES_PORT=5432
# Docker Compose host port for postgres (DBeaver). Use 5433 if Windows PostgreSQL uses 5432.
STORAGE_POSTGRES_PUBLISH_PORT=5432
STORAGE_POSTGRES_USER=datasafe
STORAGE_POSTGRES_PASSWORD=datasafe
STORAGE_POSTGRES_DB=datasafe

# SSE-S3 server-side encryption (optional master key)
# STORAGE_SSE_MASTER_KEY=change-me-32-char-minimum-secret

# OIDC / SSO (optional)
STORAGE_OIDC_ENABLED=false
STORAGE_OIDC_ISSUER=https://keycloak.example/realms/datasafe
STORAGE_OIDC_CLIENT_ID=datasafe-console
STORAGE_OIDC_CLIENT_SECRET=
STORAGE_OIDC_REDIRECT_URL=http://localhost:8080/login

# LDAP (optional — test container defaults in docs/integrations/ldap-test/)
STORAGE_LDAP_ENABLED=false
STORAGE_LDAP_URL=ldap://localhost:389
STORAGE_LDAP_BIND_DN=cn=admin,dc=datasafe,dc=local
STORAGE_LDAP_BIND_PASSWORD=ldapadmin
STORAGE_LDAP_BASE_DN=ou=users,dc=datasafe,dc=local
# Group search base for openldap groupOfNames (member attribute)
# STORAGE_LDAP_GROUP_DN=ou=groups,dc=datasafe,dc=local
# Background LDAP sync interval in minutes (0 = disabled). UI defaults to 60 when LDAP is enabled.
# STORAGE_LDAP_SYNC_INTERVAL_MINUTES=60


# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Auto-provision personal home bucket on first login (default: enabled, name: files)
STORAGE_AUTO_HOME_BUCKET=true
STORAGE_HOME_BUCKET_NAME=files

# Gateway replication worker (optional)
STORAGE_GATEWAY_WORKER_INTERVAL=2s
STORAGE_GATEWAY_MAX_RETRIES=5
STORAGE_GATEWAY_FULL_SYNC_INTERVAL=1h

