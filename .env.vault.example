# Vault overlay for Docker Compose (optional).
# Copy to .env when using docker-compose.vault.yml — see deploy/vault/README.md.

# Host path for persistent data (required on Windows dev per docker-compose.local-data.yml)
DATASAFE_DATA_ROOT=D:/datasafe-data

# Vault dev server (local profile only — never use dev mode in production)
VAULT_DEV_ROOT_TOKEN=root
VAULT_PUBLISH_PORT=8200

# Leave STORAGE_* secrets empty when using Vault Agent injection.
# Non-secret operator settings (still read from compose / .env):
STORAGE_DEV=true
# STORAGE_STRICT_SECRETS=true   # use with docker-compose.vault-product.yml
STORAGE_METADATA_BACKEND=bolt
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=datasafe
STORAGE_ADMIN_USER=admin

# Optional: point host-side vault CLI at local dev server
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=root
